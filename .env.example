# ─────────────────────────────────────────────────────────────────────────────
# TruthLens Environment Variables
# Copy to .env.local for development. NEVER commit .env.local.
# All secrets are SERVER-SIDE ONLY — no NEXT_PUBLIC_ prefix on credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Default build uses SQLite with no extra env required.
# If you later switch the Prisma schema to PostgreSQL, add DATABASE_URL here.
# DATABASE_URL="postgresql://user:password@host:5432/truthlens"

# ── CACHE ─────────────────────────────────────────────────────────────────────
# Leave empty to use in-process LRU cache (dev/single-instance)
# Set to Redis URL for production
REDIS_URL=""
# REDIS_URL="redis://localhost:6379"

# ── AI SYNTHESIS (optional — enables premium mode) ───────────────────────────
# Server-side only. NEVER prefix with NEXT_PUBLIC_.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openrouter/free"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
ANTHROPIC_API_KEY=""

# ── RETRIEVAL PROVIDERS ───────────────────────────────────────────────────────
# Google Custom Search — free tier: 100 queries/day
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_ENGINE_ID=""

# Google Fact Check Tools API — free
GOOGLE_FACT_CHECK_API_KEY=""

# Brave Search API — optional, 2000 free queries/month
BRAVE_SEARCH_API_KEY=""

# ── RATE LIMITING ─────────────────────────────────────────────────────────────
# Max analyses per IP per hour (default: 10)
RATE_LIMIT_PER_IP_PER_HOUR="10"

# Max analyses per IP per day (default: 50)
RATE_LIMIT_PER_IP_PER_DAY="50"

# ── BUDGET CONTROL ────────────────────────────────────────────────────────────
# Max Claude API calls per hour across all users (default: 100)
SYNTHESIS_BUDGET_PER_HOUR="100"

# Max retrieval API calls per hour (default: 500)
RETRIEVAL_BUDGET_PER_HOUR="500"

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
# Set to "true" to enable AI synthesis. Falls back to rules engine if false.
ENABLE_AI_SYNTHESIS="true"

# Set to "true" to require an admin key for /api/admin/* routes
ENABLE_ADMIN_AUTH="false"
ADMIN_SECRET=""

# Cache TTL in seconds for analysis results (default: 3600 = 1 hour)
CACHE_TTL_SECONDS="3600"

# Stale-while-revalidate window in seconds (default: 86400 = 24 hours)
CACHE_STALE_SECONDS="86400"

# ── NEXT.JS PUBLIC ────────────────────────────────────────────────────────────
# These are safe to expose to the browser (no credentials, just config)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TruthLens"

# Optional: self-hosted SearXNG metasearch endpoint for near-zero-cost web search
SEARXNG_URL=""
